# Benchmark output
benchmark_result.txt

# Nsight / profiling
*.qdrep
*.nsys-rep
*.ncu-rep

# wandb
wandb/

# VS Code (local IDE config — not portable across machines)
.vscode/

# Jenkins secrets and machine-generated files — never commit these
jenkins/.env
jenkins/kube/
jenkins/minikube-certs/

# Claude Code notification signal files (accidentally created at repo root
# when running on Windows with mangled path separators)
C:Users*
